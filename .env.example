# ---- LLM (默认 DeepSeek v4 Flash) ----
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=sk-replace-with-your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com
LLM_TIMEOUT=60

# ---- 切回 OpenAI 时打开以下几行 ----
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-your-openai-key
# LLM_BASE_URL=

# ---- 上传 ----
UPLOAD_DIR=./uploads
UPLOAD_MAX_MB=10
UPLOAD_ALLOWED_EXTS=.pdf,.docx,.txt

# ---- 数据库(分析缓存 / 面试题) ----
# 异步驱动(postgresql+asyncpg).本地开发推荐使用 docker-compose 启动 PostgreSQL.
DATABASE_URL=postgresql+asyncpg://job:job@localhost:5432/job_analyzer
# 缓存有效期(天).默认 7 天,过期数据可由 cleanup_expired() 清理.
CACHE_TTL_DAYS=7
# 数据库连接池配置(可选)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ---- 通用 ----
APP_DEBUG=false
LOG_LEVEL=INFO
